{
  "name": "shopmind",
  "version": "0.1.0",
  "description": "ShopMind shopping agent technical challenge setup.",
  "type": "module",
  "private": true,
  "main": "dist/server.js",
  "packageManager": "pnpm@10.29.1",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:web": "pnpm --filter shopmind-client dev",
    "build": "pnpm build:web && pnpm build:api",
    "build:api": "tsc -p tsconfig.json",
    "build:web": "pnpm --filter shopmind-client build",
    "start": "node dist/server.js",
    "check": "tsc --noEmit && pnpm --filter shopmind-client exec tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "shopmind",
    "genkit",
    "express"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@genkit-ai/google-genai": "^1.33.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "genkit": "^1.33.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
